# Copie este arquivo para terraform.tfvars e preencha os valores
# Obter project_id: gcloud config get-value project

project_id = "seu-projeto-gcp"
region     = "us-central1"
zone       = "us-central1-a"

# VM Configuration (Docker + CI)
vm_machine_type = "e2-standard-2"  # 2 vCPUs, 8 GB RAM
admin_username  = "gcpuser"

# GKE Configuration (Frontend)
gke_node_count   = 1
gke_machine_type = "e2-standard-2"  # 2 vCPUs, 8 GB RAM

# Database Configuration (Cloud SQL PostgreSQL)
db_admin_password = "sua-senha-segura-aqui"
db_tier           = "db-f1-micro"
